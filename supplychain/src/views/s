// 1. 搜索逻辑：点击搜索按钮时触发 API 请求
async function handleSearch() {
  await loadCategoryData()
}

// 2. 重置逻辑
function resetForm() {
  searchKeyword.value = ''
  multipleSelection.value = []
  loadCategoryData() // 重置后重新加载当前Tab的数据
}

// 3. 切换Tab逻辑
async function switchTab(tab: string) {
  activeTab.value = tab
  multipleSelection.value = []
  await loadCategoryData()
}

// 4. 批量删除逻辑
async function handleBatchDelete() {
  if (multipleSelection.value.length === 0) {
    ElMessage.warning('请先选择要删除的分类')
    return
  }

  try {
    await ElMessageBox.confirm(
      `确定要删除选中的 ${multipleSelection.value.length} 个分类吗?`,
      '警告',
      {
        confirmButtonText: '确定',
        cancelButtonText: '取消',
        type: 'warning',
      }
    )

    // 收集要删除的ID
    const idsToDelete = multipleSelection.value.map(item => item.id).join(',')
    
    // 发送 DELETE 请求删除选中的分类
    const res = await api.deletecategory(idsToDelete)
    if (res.code !== 1) {
      ElMessage.error(res.msg || '批量删除失败')
      return
    }
    
    ElMessage.success('删除成功')
    // 重新加载当前 Tab 的数据
    await loadCategoryData()
    multipleSelection.value = [] // 清空选中状态
  } catch (error: any) {
    if (error !== 'cancel') {
      ElMessage.error('删除操作失败')
    }
  }
}

// 5. 删除单个分类
async function handleDelete(row: any) {
  try {
    await ElMessageBox.confirm(
      `确定要删除分类 "${row.categoryName}" 吗?`,
      '警告',
      {
        confirmButtonText: '确定',
        cancelButtonText: '取消',
        type: 'warning',
      }
    )

    const res = await api.deletecategory(row.id.toString())
    if (res.code === 1) {
      ElMessage.success('删除成功')
      // 重新加载当前 Tab 的数据
      await loadCategoryData()
    } else {
      ElMessage.error(res.msg)
    }
  } catch (error: any) {
    if (error !== 'cancel') {
      ElMessage.error('删除操作失败')
    }
  }
}

// 6. 表格多选处理
function handleSelectionChange(val: any[]) {
  multipleSelection.value = val
}

// 7. 状态切换 (禁用/启用)
async function toggleStatus(row: any) {
  // 获取当前状态并切换
  const currentStatus = row.status
  const newStatus = currentStatus === 1 ? 0 : 1
  
  try {
    // 构建更新数据对象
    const updateData = {
      id: row.id,
      categoryName: row.categoryName,
      parentId: row.parentId,
      status: newStatus,
      updateTime: row.updateTime,
      parentName: row.parentName
    }
    
    // 发送更新请求
    const res = await api.editcategory(updateData)
    if (res.code !== 1) {
      throw new Error(res.msg)
    }
    
    // 成功后更新本地数据
    row.status = newStatus
    ElMessage.success(`分类 "${row.categoryName}" 状态已更新`)
  } catch (error: any) {
    // 失败时恢复原来的状态
    row.status = currentStatus
    ElMessage.error(error.message || '状态更新失败')
  }
}

// 8. 编辑分类
async function handleEdit(row: any) {
  isEditing.value = true
  dialogVisible.value = true
  // 将行数据复制到表单
  Object.assign(categoryForm, {
    id: row.id,
    categoryName: row.categoryName,
    parentId: row.parentId || null,
    status: row.status || 1
  })
}

// 9. 打开新增对话框
function openAddDialog() {
  isEditing.value = false
  dialogVisible.value = true
  // 清空表单
  Object.assign(categoryForm, {
    id: '',
    categoryName: '',
    parentId: activeTab.value === 'child' ? null : undefined, // 子类需要选择父类，父类不需要
    status: 1
  })
}

// 10. 保存分类（新增或编辑）
async function saveCategory() {
  try {
    let res
    if (isEditing.value) {
      // 编辑现有分类
      console.log('正在编辑分类:', categoryForm);
      res = await api.editcategory(categoryForm)
    } else {
      // 新增分类
      console.log('正在添加分类:', categoryForm);
      res = await api.addcategory(categoryForm)
    }
    
    if (res.code === 1) {
      ElMessage.success(isEditing.value ? '编辑成功' : '添加成功')
      dialogVisible.value = false
      // 清空表单
      Object.assign(categoryForm, {
        id: '',
        categoryName: '',
        parentId: null,
        status: 1
      })
      // 重新加载数据
      await loadCategoryData()
    } else {
      ElMessage.error(res.msg)
    }
  } catch (error: any) {
    console.error('保存分类失败:', error);
    ElMessage.error(error.message || '操作失败')
  }
}

// --- 表格行样式控制 ---
// 当状态为"禁用"时，给行添加特殊类名
function tableRowClassName({ row }: { row: any }) {
  if (row.status === 0) {
    return 'disabled-row'
  }
  return ''
}
