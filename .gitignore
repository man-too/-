# --- 依赖目录 ---
node_modules
jspm_packages
pnpm-store
.pnp
.pnp.js

# --- 构建输出目录 ---
# 这些目录通常包含打包后的生产代码，不需要提交
dist
build
out
.next
.nuxt

# --- 测试与覆盖率报告 ---
coverage
.nyc_output

# --- 环境变量文件 ---
# 包含敏感信息（如 API 密钥），严禁提交
.env
.env.local
.env..local
.env.development.local
.env.test.local
.env.production.local

# --- 日志文件 ---
npm-debug.log
yarn-debug.log
yarn-error.log
pnpm-debug.log
lerna-debug.log

# --- 编辑器与 IDE 配置 ---
# 个人编辑器配置，避免团队冲突
.idea
.vscode
.swp
.swo
.suo
.sublime-project
.sublime-workspace
.code-workspace

# --- 操作系统文件 ---
# 系统自动生成的隐藏文件
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- 缓存文件 ---
.cache
.eslintcache
.stylelintcache
.log
.tmp
.temp

# --- 类型声明文件 (如果是自动生成) ---
# 如果是手动编写的 .d.ts 则不要忽略
# .d.ts